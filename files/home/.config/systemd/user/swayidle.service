[Unit]
Description=Swayidle
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/swayidle -w \
  timeout 300  '/usr/bin/swaylock -f' \
  timeout 600  '/usr/bin/niri msg action power-off-monitors' \
  timeout 1800 '/usr/bin/systemctl suspend' \
  before-sleep '/usr/bin/swaylock -f' \
  after-resume '/usr/bin/niri msg action power-on-monitors'
Restart=on-failure
RestartSec=2

[Install]
WantedBy=graphical-session.target
