# =============================================================================
# amar319-1 — 1x 2560x1600 @ 60Hz
# Apple Cinema HD — DVI-I-2
#
# Конвертировано из Hyprland:
#   monitor=DVI-I-2, 2560x1600@60, 0x0, 1
# =============================================================================

output "DVI-I-2" {
    mode "2560x1600@60.000"
    position x=0 y=0
    scale 1.0
}
